                  "pm.test(\"Login realizado com sucesso\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "pm.collectionVariables.set(\"token\", json.access_token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
